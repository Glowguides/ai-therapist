# Google Gemini API key (free tier). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# --- Admin dashboard (optional) ---
# Password to view stored conversations at /admin. If unset, /admin is disabled.
ADMIN_PASSWORD=

# Conversation storage (Upstash Redis, free). If unset, nothing is stored.
# Create a free DB at https://console.upstash.com/ and copy the REST creds.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
